      { "name": "antinuke disable", "usage": "$antinuke disable", "description": "Disable antinuke protection" },
      { "name": "antinuke wl add", "usage": "$antinuke wl add <user>", "description": "Add user to whitelist" },
      { "name": "antinuke wl remove", "usage": "$antinuke wl remove <user>", "description": "Remove user from whitelist" },
      { "name": "antinuke wl list", "usage": "$antinuke wl list", "description": "List whitelisted users" },
      { "name": "extraowner add", "usage": "$extraowner add <user>", "description": "Add extra owner permissions" },
      { "name": "extraowner remove", "usage": "$extraowner remove <user>", "description": "Remove extra owner permissions" },
      { "name": "extraowner list", "usage": "$extraowner list", "description": "List extra owners" }
    ]
  },
