[
  {
    "category": "General",
    "icon": "Info",
    "color": "#6366f1",
    "commands": [
      { "name": "help", "usage": "$help [command]", "description": "Display help menu or info about a specific command" },
      { "name": "stats", "usage": "$stats", "description": "Show bot statistics and information" },
      { "name": "ping", "usage": "$ping", "description": "Check bot latency" },
      { "name": "invite", "usage": "$invite", "description": "Get bot invite link" },
      { "name": "avatar", "usage": "$avatar [user]", "description": "Display user's avatar" },
      { "name": "server_avatar", "usage": "$server_avatar", "description": "Display server's avatar/icon" }
    ]
  },
  {
    "category": "Moderation",
    "icon": "Shield",
    "color": "#f43f5e",
    "commands": [
      { "name": "ban", "usage": "$ban <user> [reason]", "description": "Ban a user from the server" },
      { "name": "unban", "usage": "$unban", "description": "Unban a user via interactive modal" },
      { "name": "kick", "usage": "$kick <user> [reason]", "description": "Kick a user from the server" },
      { "name": "warn", "usage": "$warn <user> [reason]", "description": "Warn a user (tracks total warnings)" },
      { "name": "timeout", "usage": "$timeout <user> <duration> [reason]", "description": "Timeout/mute a user temporarily" },
      { "name": "unmute", "usage": "$unmute <user>", "description": "Remove timeout from a user" },
      { "name": "lock", "usage": "$lock [channel]", "description": "Lock a channel (prevent sending messages)" },
      { "name": "unlock", "usage": "$unlock [channel]", "description": "Unlock a channel" },
      { "name": "hide", "usage": "$hide [channel]", "description": "Hide a channel from @everyone" },
      { "name": "unhide", "usage": "$unhide [channel]", "description": "Unhide a channel" },
      { "name": "lockall", "usage": "$lockall", "description": "Lock all channels in the server" },
      { "name": "unlockall", "usage": "$unlockall", "description": "Unlock all channels" },
      { "name": "role create", "usage": "$role create <name> [color]", "description": "Create a new role" },
      { "name": "role delete", "usage": "$role delete <role>", "description": "Delete a role" },
      { "name": "role assign", "usage": "$role assign <user> <role>", "description": "Assign a role to a user" },
      { "name": "role temp", "usage": "$role temp <user> <role> <duration>", "description": "Grant temporary role" },
      { "name": "clear", "usage": "$clear <amount>", "description": "Delete messages (various filters available)" },
      { "name": "clear all", "usage": "$clear all <amount>", "description": "Clear all messages" },
      { "name": "clear bots", "usage": "$clear bots <amount>", "description": "Clear bot messages" },
      { "name": "clear user", "usage": "$clear user <user> <amount>", "description": "Clear messages from specific user" },
      { "name": "clear contains", "usage": "$clear contains <text> <amount>", "description": "Clear messages containing specific text" },
      { "name": "clear embeds", "usage": "$clear embeds <amount>", "description": "Clear messages with embeds" },
      { "name": "clear files", "usage": "$clear files <amount>", "description": "Clear messages with files" },
      { "name": "clear images", "usage": "$clear images <amount>", "description": "Clear messages with images" },
      { "name": "snipe", "usage": "$snipe", "description": "View recently deleted messages" },
      { "name": "steal", "usage": "$steal <role/channel>", "description": "Clone/copy roles or channels" },
      { "name": "nuke", "usage": "$nuke", "description": "Purge entire channel" }
    ]
  },
  {
    "category": "Antinuke",
    "icon": "ShieldAlert",
    "color": "#f97316",
